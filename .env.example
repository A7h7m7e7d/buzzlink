# ── Pusher (free realtime, required for cross-device vibrate) ──
# Create a free app at https://dashboard.pusher.com → "Channels"
# Then copy the "App Keys" here.

# Server-side (secret) — used by the API routes
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=your_cluster

# Client-side (public) — must match the values above.
# These two are exposed to the browser, that's expected for Pusher.
NEXT_PUBLIC_PUSHER_KEY=your_key
NEXT_PUBLIC_PUSHER_CLUSTER=your_cluster

# ── OpenWeatherMap (free API key, optional bonus feature) ──
# Get a free key at https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweather_key
